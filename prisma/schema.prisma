generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Enums ──

enum Role {
  Frontend
  Backend
  Fullstack
  Mobile
  Other
}

enum Level {
  Fresher
  Junior
  Middle
  Senior
  Unknown
}

enum Status {
  new
  viewed
  applied
  saved
  archived
}

enum FeedbackType {
  relevant
  irrelevant
}

// ── Models ──

model RawPost {
  id               Int       @id @default(autoincrement())
  fb_post_id       String?
  content          String
  post_url         String
  poster_name      String
  poster_url       String
  post_url_hash    String    @unique
  content_hash     String
  group_url        String
  scrape_date      String    @default("") // YYYY-MM-DD of the scrape run that produced this post
  created_time_raw String
  created_time_utc DateTime?
  first_seen_at    DateTime
  created_at       DateTime  @default(now())

  @@index([content_hash])
  @@index([fb_post_id])
  @@index([scrape_date])
}

model Job {
  id               Int            @id @default(autoincrement())
  fb_post_id       String?
  content          String
  post_url         String
  poster_name      String
  poster_url       String
  post_url_hash    String         @unique
  content_hash     String
  role             Role
  level            Level
  yoe              Int?
  score            Int
  reason           String
  is_freelance     Boolean
  status           Status         @default(new)
  source           String         @default("manual") // "manual" | "cron"
  created_time_raw String
  created_time_utc DateTime?
  first_seen_at    DateTime
  created_at       DateTime       @default(now())

  feedbacks        UserFeedback[]

  @@index([content_hash])
  @@index([fb_post_id])
  @@index([status])
  @@index([role])
  @@index([level])
  @@index([created_at])
  @@index([source])
}

model Settings {
  id              Int    @id @default(1)
  target_groups   String // JSON array of group URLs
  target_keywords String // JSON array of common keyword strings
  blacklist       String // JSON array of blacklist terms
  allowed_roles   String @default("[\"Frontend\",\"Backend\",\"Fullstack\",\"Mobile\",\"Other\"]") // JSON array of Role values
  allowed_levels  String @default("[\"Fresher\",\"Junior\",\"Middle\",\"Unknown\"]") // JSON array of Level values
  role_keywords   String @default("{}") // JSON Record<Role, string[]> — per-role keyword lists
  common_rules    String @default("")   // Free-text common classification rules for AI prompt
  role_rules      String @default("{}") // JSON Record<Role, string> — per-role classification rules
  max_yoe               Int    @default(5)
  cron_schedule         String @default("0 */4 * * *")
  scrape_lookback_hours Int?   // relative: only process posts from the last N hours
  scrape_date_from      String? // date range: ISO date string for start bound (inclusive)
  scrape_date_to        String? // date range: ISO date string for end bound (inclusive)
  last_manual_run       DateTime? // last completed manual run timestamp
  last_cron_run         DateTime? // last completed cron run timestamp
  max_posts_per_group   Int    @default(50)
  excluded_locations    String @default("[\"HCM\",\"HCMC\",\"Ho Chi Minh\",\"TP.HCM\",\"Thành phố Hồ Chí Minh\",\"Đà Nẵng\",\"ĐN\",\"DN\"]") // JSON array of location strings to exclude
}

model UserFeedback {
  id            Int          @id @default(autoincrement())
  job_id        Int
  feedback_type FeedbackType
  created_at    DateTime     @default(now())

  job           Job          @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id])
}
